FROM eclipse-temurin:25-jdk

WORKDIR /app

# Copy Gradle wrapper and build config
COPY gradlew settings.gradle.kts build.gradle.kts gradle.properties ./
COPY gradle/ gradle/
RUN sed -i 's/\r$//' gradlew && chmod +x gradlew

# Copy source modules
COPY self-healing-core/ self-healing-core/
COPY integration-tests/ integration-tests/
COPY benchmark/ benchmark/
COPY backend/build.gradle.kts backend/build.gradle.kts

# Pre-build test classes (cached layer)
RUN ./gradlew :integration-tests:testClasses --no-daemon

# Default: run integration tests
ENTRYPOINT ["./gradlew", ":integration-tests:test", "--no-daemon"]
