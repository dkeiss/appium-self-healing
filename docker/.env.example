# Copy this file to .env and fill in your API keys
# cp .env.example .env

# Choose LLM provider:
#   Cloud:  anthropic | openai | mistral
#   Local:  local-qwen3-next | local-devstral | local-qwen3-30b | local
LLM_PROVIDER=anthropic

# API Keys (set the one matching your provider)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
MISTRAL_API_KEY=...

# Local LLM via LM Studio (used when LLM_PROVIDER=local-*)
# Leave as default for direct local runs; Docker sets host.docker.internal automatically
LM_STUDIO_URL=http://localhost:1234
