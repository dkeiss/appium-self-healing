{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":semanticCommitTypeAll(chore)",
    ":dependencyDashboard",
    ":timezone(Europe/Berlin)",
    "group:allNonMajor",
    "schedule:earlyMondays"
  ],
  "labels": ["dependencies"],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "rangeStrategy": "pin",
  "separateMinorPatch": false,
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on monday"]
  },
  "gradle": {
    "enabled": true
  },
  "gradle-wrapper": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchManagers": ["gradle"],
      "matchPackagePatterns": ["^org\\.springframework\\.boot"],
      "groupName": "spring-boot"
    },
    {
      "matchManagers": ["gradle"],
      "matchPackagePatterns": ["^org\\.springframework\\.ai"],
      "groupName": "spring-ai",
      "ignoreUnstable": false,
      "respectLatest": false,
      "description": "Spring AI ships milestones (-M*) and RCs frequently; allow them."
    },
    {
      "matchManagers": ["gradle"],
      "matchPackagePatterns": ["^io\\.cucumber"],
      "groupName": "cucumber"
    },
    {
      "matchManagers": ["gradle"],
      "matchPackagePatterns": ["^org\\.junit"],
      "groupName": "junit"
    },
    {
      "matchManagers": ["gradle"],
      "matchPackageNames": ["org.projectlombok:lombok"],
      "description": "Lombok must keep up with the JDK toolchain (currently 25); never block a JDK bump on a slow Lombok release."
    },
    {
      "matchManagers": ["gradle"],
      "matchPackagePatterns": ["^io\\.appium"],
      "groupName": "appium"
    },
    {
      "matchManagers": ["gradle"],
      "matchPackagePatterns": ["^org\\.eclipse\\.jgit"],
      "groupName": "jgit"
    },
    {
      "matchManagers": ["gradle"],
      "matchPackageNames": ["org.kohsuke:github-api"],
      "groupName": "github-api"
    },
    {
      "matchManagers": ["gradle"],
      "matchDepTypes": ["plugin"],
      "groupName": "gradle plugins"
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "github-actions"
    },
    {
      "matchUpdateTypes": ["major"],
      "addLabels": ["major-update"],
      "automerge": false
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  },
  "osvVulnerabilityAlerts": true,
  "ignorePaths": [
    "**/build/**",
    "**/node_modules/**",
    ".claude/worktrees/**"
  ]
}
